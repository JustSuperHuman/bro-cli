{
  "name": "claude-max-pool",
  "version": "0.1.0",
  "description": "Pool any number of Claude Max/Team plans behind one OpenAI- and Anthropic-compatible endpoint, with a live account/usage dashboard. Runs on Bun.",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "claude-max-pool": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts serve",
    "serve": "bun run src/index.ts serve",
    "dev": "bun --watch run src/index.ts serve",
    "accounts": "bun run src/index.ts accounts",
    "typecheck": "bunx tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "keywords": [
    "claude",
    "claude-max",
    "anthropic",
    "openai",
    "proxy",
    "bun",
    "llm"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
