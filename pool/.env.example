# Copy to .env (Bun auto-loads it) and edit as needed. All values are optional.

# Where per-account config dirs and usage state live.
# CLAUDE_POOL_DIR=~/.claude-max-pool

# Path to the Claude Code CLI, if not on PATH.
# CLAUDE_BIN=claude

# Inference backend for /v1/messages. "oauth" forwards directly to Anthropic
# with the selected account's OAuth token. "cli" uses the old claude --print path.
# CLAUDE_POOL_BACKEND=oauth

# Direct OAuth backend settings.
# ANTHROPIC_API_BASE_URL=https://api.anthropic.com
# ANTHROPIC_VERSION=2023-06-01
# ANTHROPIC_OAUTH_BETA=oauth-2025-04-20
# CLAUDE_OAUTH_TOKEN_URL=https://platform.claude.com/v1/oauth/token
# CLAUDE_OAUTH_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e
# TOKEN_REFRESH_SKEW_MS=300000

# HTTP bind address.
# HOST=127.0.0.1
# PORT=3456

# If set, /v1/* requests must send this as a Bearer token (or x-api-key).
# PROXY_API_KEY=change-me

# Per-request upstream/subprocess timeout (ms). Default 15 min.
# REQUEST_TIMEOUT_MS=900000

# Rolling usage window (ms) shown on the dashboard. Claude Max resets ~every 5h.
# USAGE_WINDOW_MS=18000000

# How long to sideline an account after a rate-limit error (ms). Default 1h.
# RATE_LIMIT_COOLDOWN_MS=3600000

# Log a line when a request fails over from one account to another. Set 0 to silence.
# LOG_FAILOVER=1
